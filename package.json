{
  "name": "testomniac_extension",
  "version": "0.1.0",
  "description": "AI-powered automated UI testing Chrome extension",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --ignore-pattern dist --ignore-pattern node_modules --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --ignore-pattern dist --ignore-pattern node_modules --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\""
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.2.1",
    "@types/chrome": "^0.1.31",
    "@types/node": "^22.10.7",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@types/webextension-polyfill": "^0.12.4",
    "@vitejs/plugin-react": "^4.5.1",
    "autoprefixer": "^10.4.22",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.7.3",
    "vite": "^5.4.21",
    "@eslint/js": "^9.38.0",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "prettier": "^3.6.2"
  },
  "dependencies": {
    "@sudobility/testomniac_scanning_service": "^0.0.2",
    "@testomniac/lib": "file:../testomniac_lib",
    "@testomniac/types": "file:../testomniac_types",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.0",
    "webextension-polyfill": "^0.12.0",
    "zustand": "^5.0.3"
  },
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/johnqh/testomniac_extension.git"
  }
}
